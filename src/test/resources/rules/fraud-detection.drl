package com.aurum.rules;

import com.aurum.corebanking.domain.rules.TransactionFact;
import java.math.BigDecimal;

// ═══════════════════════════════════════════════════
//  AURUM CORE BANKING — Fraud Detection Rules
//  Aligned with Malta FIAU & EU AML Directive 6AMLD
// ═══════════════════════════════════════════════════

// ── Rule 1: FIAU Mandatory Reporting Threshold ──
// Malta FIAU requires reporting all cash transactions ≥ €10,000
rule "FIAU Mandatory Report — Large Transaction"
    salience 100
when
    $tx : TransactionFact(
        getAmount().doubleValue() >= 10000,
        isBlocked() == false
    )
then
    $tx.setFiauReport(true);
    $tx.getFraudFlags().add("FIAU_REPORT_REQUIRED");
    System.out.println("[RULE] FIAU report required for amount: " + $tx.getAmount());
    update($tx);
end

// ── Rule 2: Velocity Breach — Rapid Fire Transactions ──
// Multiple transactions in short window = structuring suspicion
rule "Velocity Breach — Structuring Pattern"
    salience 90
when
    $tx : TransactionFact(
        getTransactionsLastHour() > 5,
        isBlocked() == false
    )
then
    $tx.getFraudFlags().add("STRUCTURING_SUSPECTED");
    $tx.setBlocked(true);
    $tx.setBlockReason("Velocity breach: " + $tx.getTransactionsLastHour()
                       + " transactions in last hour");
    update($tx);
end

// ── Rule 3: Off-Hours Large Transfer ──
rule "Off-Hours Large Transfer — Enhanced Scrutiny"
    salience 80
when
    $tx : TransactionFact(
        isOffHours() == true,
        getAmount().doubleValue() > 5000,
        isBlocked() == false
    )
then
    $tx.getFraudFlags().add("OFF_HOURS_LARGE_TRANSFER");
    $tx.setFiauReport(true);
    update($tx);
end

// ── Rule 4: Cross-Border High Risk ──
// Transfers to/from high-risk jurisdictions
rule "Cross-Border High-Risk Country"
    salience 85
when
    $tx : TransactionFact(
        (toCountry == "IR" || toCountry == "KP" || toCountry == "SY"),
        blocked == false
    )
then
    $tx.setBlocked(true);
    $tx.setBlockReason("Transfer to sanctioned/high-risk jurisdiction: "
                       + $tx.getToCountry());
    $tx.getFraudFlags().add("SANCTIONED_JURISDICTION");
    update($tx);
end

// ── Rule 5: Round Number Suspicion ──
// Exact round numbers (10000, 20000) are a classic structuring signal
rule "Round Number — Structuring Signal"
    salience 70
when
    $tx : TransactionFact(
        getAmount().remainder(new BigDecimal("1000")).compareTo(BigDecimal.ZERO) == 0,
        getAmount().doubleValue() >= 5000,
        isBlocked() == false
    )
then
    $tx.getFraudFlags().add("ROUND_NUMBER_STRUCTURING");
    update($tx);
end

// ── Rule 6: PEP Enhanced Due Diligence ──
// Politically Exposed Persons require enhanced monitoring
rule "PEP Transaction — Enhanced Due Diligence"
    salience 95
when
    $tx : TransactionFact(
        getAmount().doubleValue() > 1000,
        isBlocked() == false
    )
    // PEP flag checked separately via CustomerFact in aml-screening.drl
then
    $tx.getFraudFlags().add("EDD_REQUIRED");
    $tx.setFiauReport(true);
    update($tx);
end