# Environment Variables for Aurum Core Banking
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to git!

# ──────────────────────────────────────────────────────────────────────────
# Database Configuration (Production)
# ──────────────────────────────────────────────────────────────────────────
DB_PASSWORD=your_database_password_here

# ──────────────────────────────────────────────────────────────────────────
# Security & Encryption
# ──────────────────────────────────────────────────────────────────────────
# AES encryption key (32-byte hex string, 64 characters)
AES_SECRET_KEY=generate_a_secure_32_byte_hex_key_here

# ──────────────────────────────────────────────────────────────────────────
# Keycloak / OAuth2 Configuration
# ──────────────────────────────────────────────────────────────────────────
KEYCLOAK_JWK_URI=https://your-keycloak-server/realms/banking/protocol/openid-connect/certs
KEYCLOAK_ISSUER_URI=https://your-keycloak-server/realms/banking
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=https://your-keycloak-server/realms/banking/protocol/openid-connect/certs

# ──────────────────────────────────────────────────────────────────────────
# Optional: External Services
# ──────────────────────────────────────────────────────────────────────────
# Add your API keys, tokens, and other secrets here as needed
# EXAMPLE_API_KEY=your_api_key_here
